{
  "name": "jamp3",
  "version": "0.6.1",
  "author": "ffalt",
  "license": "MIT",
  "description": "mp3, id3v1, id3v2 - reader & writer",
  "keywords": [
    "mp3",
    "ID3",
    "ID3v1",
    "ID3v2",
    "nodejs",
    "cli"
  ],
  "bin": {
    "mp3-analyze": "bin/analyzeMP3.js",
    "id3v2-dump": "bin/dumpID3v2.js",
    "id3v1-dump": "bin/dumpID3v1.js",
    "id3v1-remove": "bin/removeID3v1.js"
  },
  "scripts": {
    "clean": "rm -Rf dist",
    "build": "npm run clean && npm run build:dist",
    "build:dist": "tsc",
    "build:deploy": "npm run build",
    "build:docs": "typedoc --options typedoc.json && touch ./docs/.nojekyll",
    "build:releaselog": "conventional-changelog -p angular -r 2 -o RELEASELOG.md",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "check": "qlty check --all",
    "release": "npx commit-and-tag-version -a",
    "coverage": "jest --coverage"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "src",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ffalt/jamp3.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "14.0.3",
    "fs-extra": "11.3.4",
    "iconv-lite": "0.7.2",
    "memory-stream": "1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/fs-extra": "11.0.4",
    "@types/jest": "30.0.0",
    "@types/node": "25.4.0",
    "@types/tmp": "0.2.6",
    "conventional-changelog": "7.2.0",
    "conventional-changelog-angular": "^8.3.0",
    "eslint": "10.0.3",
    "eslint-plugin-jest": "29.15.0",
    "eslint-plugin-unicorn": "63.0.0",
    "jest": "30.3.0",
    "tmp": "0.2.5",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  }
}
